  "files": [
    "index.d.ts",
    "globals.ts",
    "runtime/**/*.js",
    "types/**/*.d.ts",
    "tsonic.package.json",
    "tsonic.surface.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "nodejs",
    "tsonic",
    "typescript",
    "source-package",
    "native"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsoniclang/nodejs.git"
  },
  "dependencies": {
    "@tsonic/core": "10.0.46",
    "@tsonic/js": "10.0.54",
    "@types/node": "^20.14.0"
  }
}
